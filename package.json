  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^20.19.43",
    "jest": "^29.7.0",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.0",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@types/crypto-js": "^4.2.0",
    "crypto-js": "^4.2.0"
  }
}
