{
  "name": "simple-blockchain-ts",
  "version": "1.0.0",
  "description": "A lightweight blockchain implementation in TypeScript",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/main.js",
    "dev": "ts-node src/main.ts",
